<tool id="dapc_kmeans" name="Discriminant analysis of principal components to genotype data" version="0.1.0" profile="25.0">

  <description>
    using Kmeans or a k-fixed (SNPs and SSRs).
  </description>

  <requirements>
    <requirement type="package" version="2.1.11">r-adegenet</requirement>
    <requirement type="package" version="1.7_23">r-ade4</requirement>
    <requirement type="package" version="1.15.0">r-vcfr</requirement>
    <requirement type="package" version="4.0.2">r-ggplot2</requirement>
    <requirement type="package" version="4.5.2">r-base</requirement>
    <requirement type="package" version="1.2.0">r-dplyr</requirement>
  </requirements>

  <required_files>
        <include path="dapc_kmeans.R" />
    </required_files>

  <command detect_errors="exit_code"><![CDATA[
    mkdir -p outputs &&
    Rscript '$__tool_directory__/dapc_kmeans.R'
      --input  '$input_data'
      --format '$input_format'
      #if str($k_mode.k_mode_sel) == 'fixed':
        --k-fixed '$k_mode.k_fixed'
      #else:
        --k-min '$k_mode.k_min'
        --k-max '$k_mode.k_max'
        --n-start '$k_mode.n_start'
      #end if
      --n-pca-max '$n_pca_max'
      #if str($seed_mode.seed_mode_sel) == 'random':
        --seed 'NULL'
      #else if str($seed_mode.seed_mode_sel) == 'custom':
        --seed '$seed_mode.seed_value'
      #else:
        --seed '42'
      #end if
  ]]></command>

  <inputs>
    <param name="input_data" type="data" format="vcf,tabular"
           label="Upload your genetic data"
           help="File containing SNP data in VCF format or SSR/microsatellite data in tabular format (see help section)." />

    <param name="input_format" type="select" label="Select your data format">
      <option value="VCF">VCF</option>
      <option value="SSR">SSR</option>
    </param>

    <section name="k_params" title="K parameters" expanded="true">

      <conditional name="k_mode">
        <param name="k_mode_sel" type="select" label="Method for selecting the number of clusters (K)">
          <option value="auto" selected="true">Automatic (k-means)</option>
          <option value="fixed">Fixed</option>
        </param>
        <when value="auto">
          <param name="k_min" type="integer" value="1" min="1" max="20"
             label="Minimum K"
             help="Lower limit of the range of K tested."/>

          <param name="k_max" type="integer" value="10" min="2" max="50"
             label="K maximum (mode auto)"
             help="Upper limit. Increase if the selected K = K_max." />

          <param name="n_start" type="integer" value="10" min="1" max="100"
             label="Number of K-means iterations (nstart)"
             help="Number of random initialisations for K-means. Increasing this value improves stability at the expense of computation time." />

        </when>
        <when value="fixed">
          <param name="k_fixed" type="integer" value="3" min="2" max="50"
                 label="Select the value of K"
                 help="Number of clusters to be used for dAPC." />
        </when>
      </conditional>
    </section>

    <section name="advanced" title="Advanced settings" expanded="false">

      <param name="n_pca_max" type="integer" value="300" min="10"
             label="Maximum number of PCA axes"
             help="Maximum number of PCA axes supplied to K-means." />
      
      <conditional name="seed_mode">
        <param name="seed_mode_sel" type="select" label="Random seed"
               help="Controls reproducibility of K-means initialisations.">
          <option value="default" selected="true">Fixed — default (42)</option>
          <option value="custom">Fixed — custom value</option>
          <option value="random">Random (not reproducible)</option>
        </param>
        <when value="default" />
        <when value="custom">
          <param name="seed_value" type="integer" value="42" min="0"
                 label="Seed value"
                 help="Any positive integer." />
        </when>
        <when value="random" />
      </conditional>
    </section>
  </inputs>

  <outputs>
    <data name="output_ld" from_work_dir="outputs/output_ld.txt" format="tabular" label="${tool.name} - LD scores" />
    <data name="output_assign" from_work_dir="outputs/output_assign.txt" format="tabular" label="${tool.name} - Assignments" />
    <data name="output_stats" from_work_dir="outputs/output_stats.txt" format="tabular" label="${tool.name} - Summary stats" />
    <data name="output_bic" from_work_dir="outputs/output_bic.png" format="png" label="${tool.name} - BIC curve (K selection)">
      <filter>k_params['k_mode']['k_mode_sel'] == 'auto'</filter>
    </data>
    <data name="output_scree" from_work_dir="outputs/output_scree.png" format="png" label="${tool.name} - PCA scree plot" />
    <data name="output_pca" from_work_dir="outputs/output_pca.png" format="png" label="${tool.name} - PCA figure" />
    <data name="output_dapc_scatter" from_work_dir="outputs/output_dapc_scatter.png" format="png" label="${tool.name} - DAPC scatter" />
    <data name="output_posterior" from_work_dir="outputs/output_posterior.png" format="png" label="${tool.name} - Posterior membership" />
  </outputs>

  <tests>
    <test expect_num_outputs="8">
      <param name="input_data"   value="test_vcf_dapc.vcf" />
      <param name="input_format" value="VCF" />
      <section name="k_params">
        <conditional name="k_mode">
          <param name="k_mode_sel" value="auto" />
          <param name="k_min"   value="1" />
          <param name="k_max"   value="10" />
          <param name="n_start" value="10" />
        </conditional>
      </section>
      <section name="advanced">
        <param name="n_pca_max" value="100" />
      </section>
      <output name="output_stats" ftype="tabular">
        <assert_contents>
          <has_n_lines n="26" delta="1"/>
        </assert_contents>
      </output>
      <output name="output_ld" ftype="tabular">
        <assert_contents>
          <has_n_lines n="959" delta="1"/>
        </assert_contents>
      </output>
      <output name="output_assign" ftype="tabular">
        <assert_contents>
          <has_n_lines n="959" delta="1"/>
        </assert_contents>
      </output>
      <output name="output_bic" ftype="png">
        <assert_contents>
          <has_image_width width="1050"/>
          <has_image_height height="750"/>
        </assert_contents>
      </output>
      <output name="output_scree" ftype="png">
        <assert_contents>
          <has_image_width width="1200"/>
          <has_image_height height="750"/>
        </assert_contents>
      </output>
      <output name="output_pca" ftype="png">
        <assert_contents>
          <has_image_width width="1200"/>
          <has_image_height height="900"/>
        </assert_contents>
      </output>
      <output name="output_dapc_scatter" ftype="png">
        <assert_contents>
          <has_image_width width="1200"/>
          <has_image_height height="900"/>
        </assert_contents>
      </output>
      <output name="output_posterior" ftype="png">
        <assert_contents>
          <has_image_height height="600"/>
        </assert_contents>
      </output>
    </test>

